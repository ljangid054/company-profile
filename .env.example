# Example environment variables (safe to commit).
# Copy to `.env` and fill in secrets. Supabase: see `supabase/README.md`.

# --- Site (canonical URLs, OG, sitemap — use http://localhost:3000 locally) ---
NEXT_PUBLIC_SITE_URL=https://somadahookah.com

# --- Supabase (admin + storefront catalog + contact API) ---
# When URL + anon key are set, /products and APIs use Postgres categories/products.
# Force legacy static files instead: NEXT_PUBLIC_CATALOG_SOURCE=static
# NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=

# --- Optional: client-side /products catalog via fetch("/api/products") ---
# NEXT_PUBLIC_FETCH_PRODUCTS_FROM_API=1
