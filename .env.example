# Example environment variables (safe to commit).
# Copy to `.env` and fill in secrets — full walkthrough:
# docs/google-sheet-gcp-setup.md

# --- Site ---
NEXT_PUBLIC_SITE_URL=https://somadahookah.com

# --- Google Sheet (server) — Path 2 ---
# Full JSON from GCP service account key (single line in .env is typical).
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"YOUR_PROJECT",...}
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_SHEET_ID=
GOOGLE_SHEET_RANGE=Products!A:ZZ

# --- Optional: client-side /products catalog via fetch("/api/products") ---
# NEXT_PUBLIC_FETCH_PRODUCTS_FROM_API=1

# --- Path 1 (browser → Google directly; optional, not used by default) ---
# NEXT_PUBLIC_GOOGLE_SHEETS_API_KEY=
# NEXT_PUBLIC_SPREADSHEET_ID=
